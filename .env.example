# ========================================
# ZOHO CRM CONFIGURATION
# ========================================
# OAuth Configuration
ZOHO_CRM_CLIENT_ID=your_client_id_here                    # Get from Zoho CRM Developer Console
ZOHO_CRM_CLIENT_SECRET=your_client_secret_here            # Get from Zoho CRM Developer Console
ZOHO_CRM_ACCOUNTS_URL=https://accounts.zoho.com
ZOHO_CRM_API_DOMAIN=https://www.zohoapis.com
ZOHO_CRM_SCOPE=ZohoCRM.modules.contacts.ALL
ZOHO_CRM_REDIRECT_URI=http://localhost:3000/oauth/callback

# Refresh Token (obtained after first authorization)
ZOHO_CRM_REFRESH_TOKEN=your_refresh_token_here            # Generate using: node src/test/test-connection.js

# ========================================
# DATA CONNECTOR CONFIGURATION
# ========================================
# Application Configuration (Required for JWT authentication)
DS_APPLICATION_ID=oi-s-zohodataconnector
DS_NAMESPACE=zoho
DS_DATA_PATH=contacts

# Server Configuration
CONNECTOR_PORT=8080
CALLBACK_URL=https://example.com/callback                # Update with your callback URL

# ========================================
# DEVELOPMENT & TEST CONFIGURATION
# ========================================
# Environment Settings
NODE_ENV=development
LOG_LEVEL=info

# ========================================
# TEST-ONLY WALLET CONFIGURATION
# ========================================
# These are only needed for running test scripts
# NOT required for production connector operation
DATASWIFT_API_URL=https://your-instance.hubat.net        # Replace 'your-instance' with your PDA instance
DATASWIFT_USERNAME=your_username_here                    # Your Dataswyft username
DATASWIFT_PASSWORD=your_password_here                    # Your Dataswyft password